CC       := clang
CFLAGS   := -Wall -Wextra -Iinclude -g -fcolor-diagnostics
#LDFLAGS  := -lm
SRC_DIR  := src
BUILD_DIR:= build
BIN_DIR  := bin

SOURCES  := $(wildcard $(SRC_DIR)/*.c)
NAME     := $(patsubst $(SRC_DIR)/%.c,%,$(firstword $(SOURCES)))
TARGET   := $(BIN_DIR)/$(NAME)
# This converts src/main.c -> build/main.o
OBJECTS  := $(SOURCES:$(SRC_DIR)/%.c=$(BUILD_DIR)/%.o)

# Colors
CYAN   := \033[1;36m
GREEN  := \033[1;32m
RESET  := \033[0m

all: $(TARGET)

# Link the executable
$(TARGET): $(OBJECTS)
	@mkdir -p $(BIN_DIR)
	@echo "$(CYAN)Linking $(TARGET)...$(RESET)"
	$(CC) $(OBJECTS) -o $(TARGET) $(LDFLAGS)
	@echo "$(GREEN)Done!$(RESET)"

# Compile source files into object files
$(BUILD_DIR)/%.o: $(SRC_DIR)/%.c
	@mkdir -p $(BUILD_DIR)
	@echo "Compiling $<..."
	$(CC) $(CFLAGS) -c $< -o $@

clean:
	@echo "Cleaning folders..."
	rm -rf $(BUILD_DIR) $(BIN_DIR)

run: all
	@./$(TARGET)

.PHONY: all clean run